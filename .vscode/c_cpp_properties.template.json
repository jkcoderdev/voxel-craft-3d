{
  "env": {
    "emsdk": "<Emscripten SDK Repository Folder>",
    "emscriptenSysroot": "<Emscripten SDK Repository Folder>/upstream/emscripten/cache/sysroot"
  },
  "configurations": [
    {
      "name": "Emscripten",
      "compilerPath": "${emsdk}/upstream/bin/clang++.exe",
      "compilerArgs": ["--target=wasm32-unknown-emscripten", "--sysroot", "${emscriptenSysroot}"],
      "includePath": [
        "${workspaceFolder}/src/wasm/source",
        "${emscriptenSysroot}/include",
        "${emscriptenSysroot}/include/c++/v1"
      ],
      "defines": ["__EMSCRIPTEN__=1"],
      "cStandard": "c17",
      "cppStandard": "c++17",
      "intelliSenseMode": "windows-clang-x64"
    }
  ],
  "version": 4,
  "enableConfigurationSquiggles": true
}
